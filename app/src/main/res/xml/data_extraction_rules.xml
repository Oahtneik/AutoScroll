<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) backup/transfer rules.
    We allow user settings (DataStore) to be backed up so the user
    doesn't lose their preferences on device migration.
    No personal data is stored — settings are just timer values, etc.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" />
        <include domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" />
        <include domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
