    <!-- ===== Accessibility service (Play-policy critical) ===== -->
    <string name="accessibility_service_label">AutoScroll Assistant</string>
    <string name="accessibility_service_summary">
        Auto-scrolls short-video feeds for users with motor impairments.
    </string>
    <string name="accessibility_service_description">
        AutoScroll helps users who have difficulty with repeated swipe gestures
        (such as people with motor impairments, RSI, or limited hand mobility)
        navigate short-video feeds in YouTube Shorts, Instagram Reels, Facebook
        Reels, and TikTok.

        \n\nWhen enabled, AutoScroll reads the screen content of these four
        apps to:
        \n• Detect when a video has finished playing
        \n• Detect \"Skip Ad\" controls so it can dismiss them automatically
        \n• Perform a vertical swipe to advance to the next video

        \n\nAutoScroll is OFF by default. The user enables it from the
        floating control overlay or the app\'s home screen, and can stop it
        at any time. The service does not read any other apps and does not
        transmit screen content off the device.
    </string>

    <!-- ===== Onboarding ===== -->
    <string name="onboarding_welcome_title">Welcome to AutoScroll</string>
    <string name="onboarding_welcome_body">
        An accessibility helper that auto-scrolls short videos on YouTube,
        Instagram, Facebook and TikTok — built for users who find repeated
        swiping difficult or tiring.
    </string>

    <string name="onboarding_a11y_title">Enable Accessibility Service</string>
    <string name="onboarding_a11y_body">
        AutoScroll uses Android\'s Accessibility framework to read the screen
        of supported apps and perform swipes on your behalf. Nothing leaves
        your device.
    </string>
    <string name="onboarding_a11y_granted">Accessibility enabled</string>
    <string name="onboarding_a11y_grant">Open Accessibility settings</string>

    <string name="onboarding_overlay_title">Allow the floating panel</string>
    <string name="onboarding_overlay_body">
        A small pill shows the countdown and lets you pause/resume without
        leaving the video. You can disable the overlay any time in Settings.
    </string>
    <string name="onboarding_overlay_granted">Overlay allowed</string>
    <string name="onboarding_overlay_grant">Open overlay settings</string>

